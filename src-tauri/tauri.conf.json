{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ELU PEC Engine",
  "version": "2.0.0",
  "identifier": "com.earthloveunited.pec-engine",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ELU PEC Engine v2.0 — Sustainable Technology Grading",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "AI-powered sustainable technology assessment",
    "longDescription": "The ELU PEC Engine grades climate technologies using the Potential-Existence-Climate framework. Research technologies with AI or manually submit assessments for community validation.",
    "copyright": "© 2026 Earth Love United",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}